import matplotlib.pyplot as plt
from models.engine import MonteCarloEngine
from models.vanillas import VanillaPricer
from data.data_fetcher import MarketData

# 1. Get Live Market Data
params = MarketData.get_params()
print(f"Current S&P 500: {params['S0']}, Vol: {params['sigma']}, Rate: {params['r']}")

# 2. Run Engine
engine = MonteCarloEngine(S0=params['S0'], r=params['r'], sigma=params['sigma'], T=1.0, steps=252, sims=10000)
paths = engine.generate_paths(seed=42)

# 3. Visualize Paths (Recruiters love this!)
plt.figure(figsize=(10,6))
plt.plot(paths[:, :100]) # Plot first 100 paths
plt.title(f"Monte Carlo Simulation: S&P 500 (100 Paths)")
plt.xlabel("Days")
plt.ylabel("Price")
plt.grid(True)
plt.show()

# 4. Compare Prices
pricer = VanillaPricer(r=params['r'], T=1.0)
call_p = pricer.call_payoff(K=params['S0'], paths=paths)
print(f"At-the-Money Call Price: ${call_p:.2f}")
